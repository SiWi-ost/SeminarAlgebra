e: 1 + z + z^2/2 + z^3/6 + z^4/24 + z^5/120 + z^6/720;
B: B0 + B1*z + B2*z^2/2 + B3*z^3/6 + B4*z^4/24 + B5*z^5/120 + B6*z^6/720;
p: expand((e-1)*B);
coeff(p, z, 0);
coeff(p, z, 1);
coeff(p, z, 2);
coeff(p, z, 3);
coeff(p, z, 4);
coeff(p, z, 5);
coeff(p, z, 6);

p: subst(1, B0, p);
coeff(p, z, 1);
p: subst(-1/2, B1, p);
coeff(p, z, 3);
p: subst(1/6, B2, p);
coeff(p, z, 4);
p: subst(0, B3, p);
coeff(p, z, 5);
p: subst(-1/30, B4, p);
coeff(p, z, 6);
p: subst(0, B5, p);
coeff(p, z, 7);

